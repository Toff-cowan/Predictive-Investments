{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "npx tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "npx tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "scrape:jse": "python scripts/scrape_jamstockex.py"
  },
  "dependencies": {
    "@pi/api": "*",
    "@pi/db": "*",
    "@pi/env": "*",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "^11.7.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@pi/config": "*",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
