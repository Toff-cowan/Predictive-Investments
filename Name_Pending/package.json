{
  "name": "pi",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "npx turbo dev",
    "build": "npx turbo build",
    "build:render": "npm install && npx turbo build -F server",
    "check-types": "npx turbo check-types",
    "check-types": "npx turbo check-types",
    "dev:web": "npx turbo -F web dev",
    "dev:server": "npx turbo -F server dev",
    "db:push": "npx turbo -F @pi/db db:push",
    "db:studio": "npx turbo -F @pi/db db:studio",
    "db:generate": "npx turbo -F @pi/db db:generate",
    "db:migrate": "npx turbo -F @pi/db db:migrate"
  },
  "dependencies": {
    "@pi/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@pi/config": "*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.17",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.2"
}
